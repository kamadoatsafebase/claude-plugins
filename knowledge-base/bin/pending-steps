#!/usr/bin/env bash
# pending-steps [<project>]
# Print pending step filenames (sorted) for a KB project.
# With no argument: print "<project>: N pending" for every project.
# Exit 0 always; exits 2 if KB_ROOT or a named project is missing.

KB_ROOT="${KB_ROOT:-$HOME/kb}"

if [[ ! -d "$KB_ROOT/projects" ]]; then
  echo "error: KB_ROOT not found: $KB_ROOT/projects" >&2
  exit 2
fi

show_project() {
  local project="$1"
  local dir="$KB_ROOT/projects/$project/implementation/pending"
  if [[ ! -d "$dir" ]]; then
    echo "error: project not found: $project" >&2
    return 2
  fi
  local steps
  steps=$(ls "$dir" 2>/dev/null | grep '^step-.*\.md$' | sort -V)
  if [[ -z "$steps" ]]; then
    echo "$project: no pending steps"
  else
    while IFS= read -r step; do
      echo "$project: $step"
    done <<< "$steps"
  fi
}

if [[ -n "$1" ]]; then
  show_project "$1"
else
  for project_dir in "$KB_ROOT/projects"/*/; do
    [[ -d "$project_dir" ]] || continue
    show_project "$(basename "$project_dir")"
  done
fi
