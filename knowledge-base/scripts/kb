#!/usr/bin/env bash
# kb <sub-command> [args]
#
# Sub-commands:
#   pending [<project>]   Print pending step filenames (machine-readable).
#                         With a project: one line per step — "<project>: <step-file>"
#                         Without: same for every project in KB_ROOT.
#                         Exits 2 if KB_ROOT or a named project is missing.
#
#   list                  Print a human-readable overview of all projects with
#                         pending step counts and titles (from the first line of
#                         each step file).
#
# KB_ROOT is read from the environment (default: $HOME/data/kb).

KB_ROOT="${KB_ROOT:-$HOME/data/kb}"
PROJECTS="$KB_ROOT/projects"

die() { echo "error: $*" >&2; exit 2; }

require_projects_dir() {
  [[ -d "$PROJECTS" ]] || die "KB_ROOT not found: $PROJECTS"
}

# --- pending ---

pending_project() {
  local project="$1"
  local dir="$PROJECTS/$project/implementation/pending"
  [[ -d "$dir" ]] || { echo "error: project not found: $project" >&2; return 2; }
  local steps
  steps=$(ls "$dir" 2>/dev/null | grep '^step-.*\.md$' | sort -V)
  if [[ -z "$steps" ]]; then
    echo "$project: no pending steps"
  else
    while IFS= read -r step; do
      echo "$project: $step"
    done <<< "$steps"
  fi
}

cmd_pending() {
  require_projects_dir
  if [[ -n "$1" ]]; then
    pending_project "$1"
  else
    for project_dir in "$PROJECTS"/*/; do
      [[ -d "$project_dir" ]] || continue
      pending_project "$(basename "$project_dir")"
    done
  fi
}

# --- list ---

cmd_list() {
  require_projects_dir
  local found=0
  while IFS= read -r project_dir; do
    local project_name
    project_name=$(basename "$project_dir")
    local step_files=()
    while IFS= read -r f; do
      step_files+=("$f")
    done < <(find "$project_dir/implementation/pending" -maxdepth 1 -name 'step-*.md' 2>/dev/null | sort -V)
    echo "$project_name  (${#step_files[@]} pending steps)"
    for f in "${step_files[@]}"; do
      echo "  • $(basename "$f") — $(head -1 "$f")"
    done
    echo
    found=1
  done < <(find "$PROJECTS" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sort)
  [[ "$found" -eq 0 ]] && echo "No KB projects found."
}

# --- dispatch ---

case "${1:-}" in
  pending) shift; cmd_pending "$@" ;;
  list)    shift; cmd_list "$@" ;;
  "")      echo "usage: kb <pending|list> [args]" >&2; exit 1 ;;
  *)       echo "unknown sub-command: $1" >&2; echo "usage: kb <pending|list> [args]" >&2; exit 1 ;;
esac
